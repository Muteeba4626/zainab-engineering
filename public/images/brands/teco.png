	<div class="header-searchContainer header-searchContainer--hidden">
		<div class="container">
			<form class="header-searchForm header-searchForm--hidden" action="/zh-tw/search/">
				<input class="header-searchInput" type="search" required name="q" placeholder="請輸入關鍵字">
				<button class="header-searchSentBtn"  title="送出"><i class="icon icon--search"></i></button>
			</form>
		</div>
	</div>
</header>

	<script nonce="5hBkPoZ9qZGza3yv">
		const header = document.querySelector('.header');
		const headerContainer = document.querySelector('.header-container');
		const navContainer = document.querySelector('.header-navContainer');
		const dataLv1Links = document.querySelectorAll('.header-lv1Link[data-lv1]');
		const dataLv2Links = document.querySelectorAll('.header-link[data-lv2]');
		const dataLv3Links = document.querySelectorAll('.header-link[data-lv3]');
		const lv2Containers = document.querySelectorAll(`.header-lv2Container`);
		const lv3Containers = document.querySelectorAll(`.header-lv3Container`);
		const lv4Containers = document.querySelectorAll(`.header-lv4Container`);
		const navMenu = document.querySelector('.header-navMenu');
		const mobileMenuBtn = document.querySelector('.header-functionBtn--menu');
		const navMenuCloseBtn = document.querySelector('.header-navMenuClose');
		const languageBtn = document.querySelector('.header-functionBtn--language');
		const languageContainer = document.querySelector('.header-languageContainer');
		const searchBtn = document.querySelector('.header-functionBtn--search');
		const searchContainer = document.querySelector('.header-searchContainer');
		const searchForm = document.querySelector('.header-searchForm');
		const lv3BackBtns = document.querySelectorAll('.header-backBtn--lv3');
		const lv4BackBtns = document.querySelectorAll('.header-backBtn--lv4');
		const languageBackBtn = document.querySelector('.header-backBtn--language');
		const mobileLanguageBtn = document.querySelector('.header-mobileLanguageBtn');
		let lastScrollTop = 0;

		// Monitor scroll event
		window.addEventListener('scroll', function() {
			const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

			if (scrollTop === 0) {
				headerContainer.classList.remove('header-container--scrolling');
				lastScrollTop = scrollTop;
				return;
			}else {
				headerContainer.classList.add('header-container--scrolling');
			}

			lastScrollTop = scrollTop;
		});

		const hideAllContainers = (containers, className) => {
			containers.forEach(container => container.classList.add(className));
		};
		const toggleContainer = (container, title, attributeName, className) => {
			container.classList.toggle(className, container.getAttribute(attributeName) !== title);
		};

		// 點擊 lv1 連結時，顯示對應的 lv2 選單
		dataLv1Links.forEach(lv1Link => {
			lv1Link.addEventListener('click', (e) => {
				e.preventDefault();
				const lv1Title = lv1Link.getAttribute('data-lv1');
				const targetContainer = document.querySelector(`.header-lv2Container[data-lv1Child="${lv1Title}"]`);
				lv1Link.classList.toggle('header-lv1Link--active');
				dataLv1Links.forEach(l => l!== lv1Link && l.classList.remove('header-lv1Link--active'));
				hideAllContainers(lv3Containers, 'header-lv3Container--hidden');
				hideAllContainers(lv4Containers, 'header-lv4Container--hidden');
				dataLv2Links.forEach(l => l.classList.remove('header-link--active'));
				dataLv3Links.forEach(l => l.classList.remove('header-link--active'));

				lv2Containers.forEach(container => {
					if (container === targetContainer) {
						container.classList.toggle('header-lv2Container--hidden');
					} else {
						container.classList.add('header-lv2Container--hidden');
					}
				});
				if (targetContainer && window.innerWidth >= 1200) {
					navMenu.classList.toggle('header-navMenu--open',
					!targetContainer.classList.contains('header-lv2Container--hidden'));
					}
			});
		});

		// 點擊 lv2 連結時，顯示對應的 lv3 選單
		dataLv2Links.forEach(lv2Link => {
			lv2Link.addEventListener('click', (e) => {
				if(!lv2Link.classList.contains('header-link--hasChild')) return;
				e.preventDefault();
				dataLv2Links.forEach(l => l.classList.remove('header-link--active'));
				dataLv3Links.forEach(l => l.classList.remove('header-link--active'));
				lv2Link.classList.add('header-link--active');
				const lv2Title = lv2Link.getAttribute('data-lv2');
				hideAllContainers(lv4Containers, 'header-lv4Container--hidden');
				lv3Containers.forEach(container =>
					toggleContainer(container, lv2Title, 'data-lv2Child', 'header-lv3Container--hidden'));
			});
		});

		// 點擊 lv3 連結時，顯示對應的 lv4 選單
		dataLv3Links.forEach(lv3Link => {
			lv3Link.addEventListener('click', (e) => {
				if(!lv3Link.classList.contains('header-link--hasChild')) return;
				e.preventDefault();
				dataLv3Links.forEach(l => l.classList.remove('header-link--active'));
				lv3Link.classList.add('header-link--active');
				const lv3Title = lv3Link.getAttribute('data-lv3');
				lv4Containers.forEach(container =>
					toggleContainer(container, lv3Title, 'data-lv3Child', 'header-lv4Container--hidden'));
			});
		});

       	// 關閉選單
		const closeNavMenu = () => {
			navMenu.classList.remove('header-navMenu--open');
			mobileMenuBtn.classList.remove('header-functionBtn--menuOpen');
			dataLv1Links.forEach(link => link.classList.remove('header-lv1Link--active'));
			dataLv2Links.forEach(l => l.classList.remove('header-link--active'));
			dataLv3Links.forEach(l => l.classList.remove('header-link--active'));
			hideAllContainers(lv2Containers, 'header-lv2Container--hidden');
			hideAllContainers(lv3Containers, 'header-lv3Container--hidden');
			hideAllContainers(lv4Containers, 'header-lv4Container--hidden');
		};

		navMenuCloseBtn.addEventListener('click', closeNavMenu);

		function hideSearch() {
			searchContainer.classList.add('header-searchContainer--hidden');
			searchForm.classList.add('header-searchForm--hidden');
		}

		function hideLanguage() {
			languageContainer.classList.add('header-languageContainer--hidden');
		}

		languageBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			hideSearch();
			closeNavMenu();
			languageContainer.classList.toggle('header-languageContainer--hidden');
		});

		mobileLanguageBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			languageContainer.classList.remove('header-languageContainer--hidden');
			languageContainer.classList.add('header-languageContainer--mobileOpen');
		});

		languageBackBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			languageContainer.classList.add('header-languageContainer--hidden');
			languageContainer.classList.remove('header-languageContainer--mobileOpen');
		});

		searchBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			hideLanguage();
			closeNavMenu();
			searchContainer.classList.toggle('header-searchContainer--hidden');
			const hide = searchForm.classList.toggle('header-searchForm--hidden');
			const input = searchForm.querySelector('input');
			input.value = '';
			if (!hide) { input.focus(); }
		});

		// mobile menu button
		mobileMenuBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			hideSearch();
			if(mobileMenuBtn.classList.contains('header-functionBtn--menuOpen')){
				mobileMenuBtn.classList.remove('header-functionBtn--menuOpen');
				navMenu.classList.remove('header-navMenu--open');
				languageContainer.classList.add('header-languageContainer--hidden');
				languageContainer.classList.remove('header-languageContainer--mobileOpen');
				closeNavMenu()
			}else{
				mobileMenuBtn.classList.add('header-functionBtn--menuOpen');
				navMenu.classList.add('header-navMenu--open');
			}
		});

		// 點擊 lv3 返回按鈕
		lv3BackBtns.forEach(btn => {
			btn.addEventListener('click', (e) => {
				const parentContainer = btn.closest('.header-lv3Container');
				parentContainer.classList.add('header-lv3Container--hidden');
				const dataLv2Name = parentContainer.getAttribute('data-lv2Child');
				const matchingLv2Link = document.querySelector(`.header-link[data-lv2="${dataLv2Name}"]`);
				if (matchingLv2Link) {
					matchingLv2Link.classList.remove('header-link--active');
				}
			});
		});

		// 點擊 lv4 返回按鈕
		lv4BackBtns.forEach(btn => {
			btn.addEventListener('click', (e) => {
				console.log('LV4 Back button clicked');
				const parentContainer = btn.closest('.header-lv4Container');
				parentContainer.classList.add('header-lv4Container--hidden');
				const dataLv3Name = parentContainer.getAttribute('data-lv3Child');
				const matchingLv3Link = document.querySelector(`.header-link[data-lv3="${dataLv3Name}"]`);
				if (matchingLv3Link) {
					matchingLv3Link.classList.remove('header-link--active');
				}
			});
		});

		// 點擊外部關閉
		document.addEventListener('click', (e) => {
			if (!searchContainer.contains(e.target) && !searchBtn.contains(e.target)) hideSearch();
			if (!languageContainer.contains(e.target) && !languageBtn.contains(e.target)) hideLanguage();
			if (!navMenu.contains(e.target) && !navContainer.contains(e.target)) {
				closeNavMenu()
			};
		});

		// resize 關閉行為
		window.addEventListener('resize', () => {
			if (window.innerWidth >= 1200) {
				languageContainer.classList.add('header-languageContainer--hidden');
				languageContainer.classList.remove('header-languageContainer--mobileOpen');
				closeNavMenu();
			}
		});
	</script>

	<main class="container pt-16">
		<div class="py-15 md:py-20 lg:py-25 flex flex-col gap-15">
			<div class="gridContainer">
				<div class="col-span-4 md:col-start-4 md:col-end-10 lg:col-start-5 lg:col-end-9">
