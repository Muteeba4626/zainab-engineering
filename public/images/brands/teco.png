<script type="module" nonce="5hBkPoZ9qZGza3yv">
	const lv1Items = document.querySelectorAll('.footer-lv1Item');
	const lv2Lists = document.querySelectorAll('.footer-lv2List');
	lv1Items.forEach((item) => {
		item.addEventListener('click', () => {
			lv1Items.forEach((btn) => {
				if (btn !== item) {
					btn.classList.remove('footer-lv1ItemButton--expanded');
				}
				item.classList.toggle('footer-lv1ItemButton--expanded');
			});
			lv2Lists.forEach((list) => {
				if (list.dataset.lv1 !== item.dataset.lv1) {
					list.classList.remove('footer-lv2List--expanded');
				}else{
					list.classList.toggle('footer-lv2List--expanded');
				}
			});
		});
	});
</script>

	
